# AutoTrade Pro — Environment variable template
# Copy to .env and fill in your values.
# PAPER TRADING ONLY — no real money is ever used.

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Session-mode pooler URL (port 5432) required for asyncpg
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Redis (Upstash — TLS) ─────────────────────────────────────────────────────
REDIS_URL=rediss://default:[UPSTASH-PASSWORD]@[UPSTASH-ENDPOINT].upstash.io:6379

# ── Market data ───────────────────────────────────────────────────────────────
# yfinance is primary (no key needed)
# Twelve Data is secondary — https://twelvedata.com
TWELVEDATA_KEY=your_twelvedata_key_here

# ── News ──────────────────────────────────────────────────────────────────────
# India-first: free RSS (Moneycontrol/Business Standard/Mint/ET) needs no key.
# These optional keys enrich coverage:
NEWSDATA_KEY=          # https://newsdata.io — India business news, 200 req/day free
FINNHUB_KEY=your_finnhub_key_here   # https://finnhub.io — global news (US-focused)
NEWSAPI_KEY=           # https://newsapi.org — optional global secondary

# ── HuggingFace Hub (optional, for faster FinBERT first-load) ─────────────────
# Anonymous downloads are rate-limited. A free read-token at
# https://huggingface.co/settings/tokens removes the limit and silences the
# "You are sending unauthenticated requests" warning at FinBERT cold-start.
HF_TOKEN=

# ── LLM ───────────────────────────────────────────────────────────────────────
# Groq for fast day-to-day inference — https://console.groq.com
GROQ_API_KEY=your_groq_key_here
# Claude for detailed explanations — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Paper trading parameters ──────────────────────────────────────────────────
PAPER_TRADING_BALANCE=500000.0       # ₹5,00,000 starter wallet
MAX_RISK_PER_TRADE=0.02
MAX_OPEN_POSITIONS=5
PAPER_MODE=true

# ── AI Trading Agent ──────────────────────────────────────────────────────────
# Master kill-switch. Defaults to false in code; set true to let
# run_master_intelligence_cycle drive paper trades during NSE hours.
AGENT_ENABLED=false
AGENT_PAPER_MODE=true
# Timeframe + warmup must match what's actually in the candles table.
# 1h × 60 bars ≈ 8 trading days — enough for RSI/EMA50 settling.
# AGENT_TIMEFRAME=1h
# AGENT_WARMUP_BARS=60

# ── Zerodha KiteConnect v3 ────────────────────────────────────────────────────
# Get your API key + secret from https://developers.kite.trade
# ZERODHA_REDIRECT_URL must match exactly what you registered in the Kite console
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here
ZERODHA_ACCESS_TOKEN=          # filled automatically after OAuth login
ZERODHA_REDIRECT_URL=http://localhost:8000/api/v1/zerodha/callback
ZERODHA_ENABLED=false

# ── Master Intelligence Hub — 7-factor universe ───────────────────────────────
# The Hub deep-scores the top-N most-liquid NSE equities every 15 min with
# technical + news + fundamentals + earnings + sector + macro + options. The
# agent ONLY auto-trades symbols in this universe (no technical-only fallback).
# Rebuilt daily by 30-day average turnover.
HUB_UNIVERSE_SIZE=500
HUB_UNIVERSE_MIN_TURNOVER_CR=5.0
# HUB_SYMBOLS=                  # optional: comma-separated override (else use DB table)
# Universe rebuild runs daily at 08:20 IST (02:50 UTC) via Celery beat.

# Mantle (AWS Bedrock, OpenAI-compatible) — primary LLM layer
MANTLE_API_KEY=
MANTLE_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
MANTLE_MODEL=openai.gpt-oss-120b
MANTLE_ENABLED=true
